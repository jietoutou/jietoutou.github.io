    # 1. 读取视频并转 base64
    print("=" * 60)
    print("  长护险护理服务智能视觉检测+评分一体化系统")
    print("  模型: qwen3-vl-32b-instruct",)
    print("=" * 60)
    
    if not os.path.exists(video_path):
        print(f"❌ 视频文件不存在: {video_path}")
        return None
    
    print(f"📹 正在读取视频: {video_path}")
    with open(video_path, "rb") as f:
        video_b64 = base64.b64encode(f.read()).decode("utf-8")
    video_url = f"data:video/mp4;base64,{video_b64}"
    print(f"✅ 视频读取完成，大小: {len(video_b64)/1024/1024:.1f} MB")
    
    # 2. 调用大模型
    
    print("   （由于评估标准非常详细，请耐心等待约2-5分钟）")
    
    response = MultiModalConversation.call(
        model="qwen3-vl-32b-instruct",
        messages=[{
            "role": "user",
            "content": [
                {"video": video_url},
                {"text": FULL_ASSESSMENT_STANDARD}
            ]
        }],
        api_key=api_key,
        timeout=300  # 5分钟超时
    )
    
    # 3. 处理返回结果
    if response.status_code != 200:
        print(f"❌ API 调用失败: {response.status_code}")
        print(f"   错误信息: {response.message}")
        return None
    
    result_text = response.output.choices[0].message.content[0]["text"]
    print("\n" + "=" * 60)
    print("  📋 评估结果")
    print("=" * 60)
    print(result_text)
    
    # 4. 尝试解析 JSON
    try:
        json_match = re.search(r'\{.*\}', result_text, re.DOTALL)
        if json_match:
            report = json.loads(json_match.group())
            print("\n" + "=" * 60)
            print("  📊 结构化评估报告")
            print("=" * 60)
            print(f"  服务类别: {report.get('service_category', 'N/A')}")
            print(f"  服务项目: {report.get('service_name', 'N/A')}")
            print(f"  项目代码: {report.get('service_code', 'N/A')}")
            print(f"  总分: {report.get('total_score', 'N/A')} / 100")
            print(f"  等级: {report.get('grade', 'N/A')}")
            if report.get('veto_triggered'):
                print(f"  ⚠️  否决项触发: {report.get('veto_reason', 'N/A')}")
            print(f"  --- 维度得分 ---")
            for dim, score in report.get('dimension_scores', {}).items():
                print(f"    {dim}: {score}/100")
            print(f"  --- 动作明细 ---")
            for action in report.get('action_details', []):
                print(f"    {action.get('action_name')}: {action.get('actual_score')}/{action.get('full_score')}")
                if action.get('deduction_reason'):
                    print(f"      扣分原因: {action.get('deduction_reason')}")
            return report
    except Exception as e:
        print(f"⚠️  JSON解析失败: {e}")
        print("  （将使用原始文本结果）")
    
    return result_text


